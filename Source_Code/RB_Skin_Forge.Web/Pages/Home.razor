@page "/"
@implements IDisposable
@inject IAssetPipeline Pipeline
@inject Localizer L
@inject Microsoft.JSInterop.IJSRuntime JS

<PageTitle>RB Skin Forge</PageTitle>

<div class="forge">

    <header class="appbar">
        <div class="brand">
            <img class="brand__logo" src="favicon.png" alt="RB Skin Forge logo" />
            <div class="brand__text">
                <span class="brand__name">RB Skin Forge</span>
                <span class="brand__sub">Roblox clothing &amp; 3D mesh forge</span>
            </div>
        </div>
        <div class="appbar__controls">
            <label class="control">
                <span class="control__label">@L.T("nav.language")</span>
                <span class="select-wrap">
                    <select @onchange="OnLanguageChanged">
                        @foreach (var lang in Languages.All)
                        {
                            <option value="@lang.Code" selected="@(lang.Code == L.CurrentCode)">@lang.NativeName</option>
                        }
                    </select>
                </span>
            </label>
            <div class="control">
                <span class="control__label">@L.T("nav.theme")</span>
                <div class="seg-group" role="group" aria-label="@L.T("nav.theme")">
                    <button class="@SegClass("auto")" @onclick='() => SetTheme("auto")'>@L.T("theme.auto")</button>
                    <button class="@SegClass("light")" @onclick='() => SetTheme("light")'>@L.T("theme.light")</button>
                    <button class="@SegClass("dark")" @onclick='() => SetTheme("dark")'>@L.T("theme.dark")</button>
                </div>
            </div>
        </div>
    </header>

    <p class="hero">@L.T("app.tagline")</p>

    <div class="forge-grid">
        <!-- Drop Zone + controls -->
        <section class="card">
            <div class="card__head"><h2>@L.T("panel.dropzone")</h2></div>

            <label class="field">
                <span class="field__label">@L.T("field.bodypart")</span>
                <span class="select-wrap">
                    <select @bind="_bodyPart">
                        @foreach (var part in Enum.GetValues<BodyPart>())
                        {
                            <option value="@part">@L.BodyPartName(part)</option>
                        }
                    </select>
                </span>
            </label>

            <label class="dropzone">
                <InputFile OnChange="OnFilesSelected" multiple
                           accept=".png,.jpg,.jpeg,.bmp,.tga,.obj,.fbx" />
                <span class="dropzone__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4" /><path d="M8 8l4-4 4 4" /><path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" /></svg>
                </span>
                <span class="dropzone__title">@L.T("dropzone.hint")</span>
                <span class="dropzone__formats">
                    <span class="fmt">PNG</span><span class="fmt">JPG</span><span class="fmt">OBJ</span><span class="fmt">FBX</span>
                </span>
            </label>

            @if (_items.Count > 0)
            {
                <ul class="filelist">
                    @foreach (var item in _items)
                    {
                        <li class="@(_selected == item ? "sel" : "")" @onclick="() => Select(item)">
                            <span class="file-ico">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" /><path d="M14 3v6h6" /></svg>
                            </span>
                            <span class="fname">@item.Name</span>
                            @if (item.Result is not null)
                            {
                                <span class="chip chip--@item.Result.State">@L.StateName(item.Result.State)</span>
                            }
                        </li>
                    }
                </ul>
            }

            <button class="btn btn--primary btn--block" disabled="@(_busy || _items.Count == 0)" @onclick="Run">
                @if (_busy)
                {
                    <span>@L.T("btn.processing")</span>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.7 4.7L18.5 8l-4.8 1.3L12 14l-1.7-4.7L5.5 8l4.8-1.3z" /><path d="M19 12l.9 2.4 2.6.9-2.6.9L19 19l-.9-2.8-2.6-.9 2.6-.9z" /></svg>
                    <span>@L.T("btn.generate")</span>
                }
            </button>

            @if (_items.Count > 1 && _processedCount > 0)
            {
                <p class="batch-summary">@string.Format(L.T("batch.summary"), _successCount, _items.Count)</p>
            }
        </section>

        <!-- Preview -->
        <section class="card">
            <div class="card__head"><h2>@L.T("panel.preview")</h2></div>
            <div class="preview-frame">
                @if (_selected?.PreviewUrl is not null)
                {
                    <img class="preview" src="@_selected.PreviewUrl" alt="Preview" />
                }
                else
                {
                    <div class="preview placeholder">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="9" cy="9" r="2" /><path d="M21 15l-5-5L5 21" /></svg>
                        <span>@L.T("preview.empty")</span>
                    </div>
                }
            </div>
        </section>
    </div>

    <!-- Console & Stats -->
    <section class="card">
        <div class="card__head">
            <h2>@L.T("panel.console")</h2>
            @if (_selected?.Result is not null)
            {
                <span class="chip chip--@_selected.Result.State">@L.StateName(_selected.Result.State)</span>
            }
        </div>

        @if (_selected?.Result is not null)
        {
            var r = _selected.Result.Report;
            <div class="statgrid">
                @if (r.OutputWidth > 0)
                {
                    <div class="stat">
                        <span class="stat__label">@L.T("stats.dimensions")</span>
                        <span class="stat__value">@r.OutputWidth&times;@r.OutputHeight <span class="unit">px</span></span>
                    </div>
                }
                @if (r.TriangleCount > 0)
                {
                    <div class="stat">
                        <span class="stat__label">@L.T("stats.triangles")</span>
                        <span class="stat__value">
                            @r.TriangleCount.ToString("N0")
                            @if (r.WasDecimated)
                            {
                                <em class="tag">@L.T("stats.decimated")</em>
                            }
                        </span>
                    </div>
                }
                @if (r.VertexCount > 0)
                {
                    <div class="stat">
                        <span class="stat__label">@L.T("stats.vertices")</span>
                        <span class="stat__value">@r.VertexCount.ToString("N0")</span>
                    </div>
                }
                @if (r.MaterialCount > 0)
                {
                    <div class="stat">
                        <span class="stat__label">@L.T("stats.materials")</span>
                        <span class="stat__value">@r.MaterialCount</span>
                    </div>
                }
                @if (r.AttachmentCount > 0)
                {
                    <div class="stat">
                        <span class="stat__label">@L.T("stats.attachments")</span>
                        <span class="stat__value">@r.AttachmentCount</span>
                    </div>
                }
                @if (r.BoundsX > 0 || r.BoundsY > 0 || r.BoundsZ > 0)
                {
                    <div class="stat">
                        <span class="stat__label">@L.T("stats.bounds")</span>
                        <span class="stat__value" style="font-size:0.92rem">@FormatBounds(r)</span>
                    </div>
                }
                <div class="stat">
                    <span class="stat__label">@L.T("stats.outputsize")</span>
                    <span class="stat__value">@FormatBytes(r.TextureSizeBytes)</span>
                </div>
            </div>
        }

        <div class="terminal">
            <div class="terminal__bar">
                <span></span><span></span><span></span>
                <span class="terminal__title">@L.T("panel.console")</span>
            </div>
            <pre class="terminal__body">@ConsoleText()</pre>
        </div>

        <div class="actions">
            @if (_selected?.Result?.Output is not null)
            {
                <button class="btn btn--ghost" @onclick="DownloadOutput">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12" /><path d="M8 11l4 4 4-4" /><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" /></svg>
                    <span>@L.T("btn.downloadoutput")</span>
                </button>
            }
            @if (_selected?.Result is not null)
            {
                <button class="btn btn--ghost" @onclick="DownloadLog">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12" /><path d="M8 11l4 4 4-4" /><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" /></svg>
                    <span>@L.T("btn.downloadlog")</span>
                </button>
            }
        </div>
    </section>

    <footer class="credit">Creators: <strong>SpaceSquare &amp; Claude Code</strong> | Owner: <strong>SpaceSquare</strong></footer>
</div>

@code {
    private sealed class BatchItem
    {
        public required string Name { get; init; }
        public required byte[] Data { get; init; }
        public ProcessingResult? Result { get; set; }
        public string? PreviewUrl { get; set; }
    }

    private readonly List<BatchItem> _items = new();
    private BatchItem? _selected;
    private BodyPart _bodyPart = BodyPart.Torso;

    private bool _busy;
    private int _processedCount;
    private int _successCount;
    private string _theme = "auto";
    private readonly List<string> _log = new();

    // 25 MB upload guard (meshes can be larger than images).
    private const long MaxUploadBytes = 25 * 1024 * 1024;

    protected override void OnInitialized()
    {
        L.Changed += OnLocChanged;
        _log.Add("RB Skin Forge ready. Add image or mesh files to begin.");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var savedLang = await JS.InvokeAsync<string?>("rbGetLang");
            if (!string.IsNullOrEmpty(savedLang)) L.SetLanguage(savedLang);
            _theme = await JS.InvokeAsync<string>("rbGetTheme");
            StateHasChanged();
        }
        catch { /* JS not ready / prerender — ignore */ }
    }

    private void OnLocChanged() => InvokeAsync(StateHasChanged);

    private async Task OnLanguageChanged(ChangeEventArgs e)
    {
        var code = e.Value?.ToString() ?? "en";
        L.SetLanguage(code);
        try { await JS.InvokeVoidAsync("rbSetLang", code); } catch { }
    }

    private async Task SetTheme(string mode)
    {
        _theme = mode;
        try { await JS.InvokeVoidAsync("rbSetTheme", mode); } catch { }
    }

    private string SegClass(string mode) => _theme == mode ? "seg active" : "seg";

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        foreach (var file in e.GetMultipleFiles(maximumFileCount: 20))
        {
            try
            {
                using var stream = file.OpenReadStream(MaxUploadBytes);
                using var ms = new MemoryStream();
                await stream.CopyToAsync(ms);
                var item = new BatchItem { Name = file.Name, Data = ms.ToArray() };
                _items.Add(item);
                _selected ??= item;
            }
            catch (Exception ex)
            {
                _log.Add($"[Error] Could not read '{file.Name}': {ex.Message}");
            }
        }
        _processedCount = 0;
        _successCount = 0;
    }

    private void Select(BatchItem item) => _selected = item;

    private async Task Run()
    {
        if (_items.Count == 0) return;

        _busy = true;
        _processedCount = 0;
        _successCount = 0;
        StateHasChanged();

        foreach (var item in _items)
        {
            var input = new AssetInput { FileName = item.Name, Data = item.Data, BodyPart = _bodyPart };
            item.Result = await Pipeline.ProcessAsync(input);

            if (item.Result.PreviewImage is not null)
                item.PreviewUrl = $"data:image/png;base64,{Convert.ToBase64String(item.Result.PreviewImage)}";

            _processedCount++;
            if (item.Result.State == TaskState.Synchronized) _successCount++;
            _selected = item;
            StateHasChanged();
        }

        _busy = false;
    }

    private string ConsoleText() =>
        _selected?.Result is not null ? string.Join('\n', _selected.Result.Log) : string.Join('\n', _log);

    private async Task DownloadOutput()
    {
        var r = _selected?.Result;
        if (r?.Output is null) return;
        var b64 = Convert.ToBase64String(r.Output);
        await JS.InvokeVoidAsync("rbDownload", r.OutputFileName ?? "rb_skin_forge_output", r.OutputContentType, b64);
    }

    private async Task DownloadLog()
    {
        var r = _selected?.Result;
        if (r is null) return;
        var text = string.Join('\n', r.Log);
        var b64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(text));
        await JS.InvokeVoidAsync("rbDownload", "rb_skin_forge_log.txt", "text/plain", b64);
    }

    private static string FormatBounds(QualityReport r) =>
        $"{r.BoundsX:0.##} × {r.BoundsY:0.##} × {r.BoundsZ:0.##}";

    private static string FormatBytes(long bytes) =>
        bytes < 1024 ? $"{bytes} B" :
        bytes < 1024 * 1024 ? $"{bytes / 1024.0:0.0} KB" :
        $"{bytes / (1024.0 * 1024.0):0.0} MB";

    public void Dispose() => L.Changed -= OnLocChanged;
}
